# ─── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database (PostgreSQL) ────────────────────────────────
# Option 1: Use DATABASE_URL (Neon, Supabase, Railway, etc.)
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Option 2: Use individual params (local Docker)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=smartcart
DATABASE_PASSWORD=password123
DATABASE_NAME=smartcart

# ─── Redis ────────────────────────────────────────────────
# Option 1: Use REDIS_URL (Upstash, Render, Railway, etc.)
# REDIS_URL=rediss://default:password@host:port

# Option 2: Use individual params (local Docker)
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Queue ────────────────────────────────────────────────
QUEUE_PROVIDER=bullmq

# ─── OpenAI (optional — app works without it) ────────────
OPENAI_API_KEY=

# ─── Razorpay (optional — get test keys from dashboard.razorpay.com) ─
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ─── Stripe (optional — get test keys from dashboard.stripe.com) ─────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Frontend URL (for CORS) ─────────────────────────────
FRONTEND_URL=http://localhost:5173
